# CareerOneStop API Credentials
CAREERONESTOP_USER_ID=
CAREERONESTOP_TOKEN=

# ── Google OAuth (registered in Google Cloud Console) ────────────────────────
# Used server-side in server.ts to exchange authorization codes and proxy
# Gmail / Calendar API calls. Never expose CLIENT_SECRET to the browser.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Microsoft / Azure OAuth (registered in Azure Portal) ─────────────────────
# VITE_ prefix exposes the value to the Vite browser bundle (client-safe).
# CLIENT_SECRET is server-only — never prefix it with VITE_.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:3000
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
