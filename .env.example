# ── Niche / White-label config ────────────────────────────────────────────────
# Copy to .env.local and fill in values for each deployment.
# VITE_* vars are read by the Vite frontend build.
# Non-prefixed vars are read by the backend (server.ts / api.ts).

# App branding
VITE_APP_NAME=Trussk
NICHE_APP_NAME=Trussk

# Niche identity — used in AI prompt, feedback tagging, and UI copy
VITE_NICHE_ID=heavy_civil
VITE_NICHE_DISPLAY=Heavy Civil & Infrastructure
VITE_NICHE_TAGLINE=Connecting the best heavy civil talent with the firms that need them.
NICHE_DISPLAY=Heavy Civil & Infrastructure

# Industries the AI will accept jobs from (comma-separated)
VITE_NICHE_INDUSTRIES=Heavy Civil Engineering,Infrastructure (roads, bridges, utilities, drainage),Road & Bridge construction,Heavy Highway construction,Marine Construction
NICHE_INDUSTRIES=Heavy Civil Engineering,Infrastructure (roads, bridges, utilities, drainage),Road & Bridge construction,Heavy Highway construction,Marine Construction

# Market Intelligence widget defaults
VITE_MARKET_SOC=11-9021
VITE_MARKET_LOCATION=Florida
VITE_MARKET_JOB_TITLE=Construction Manager

# ── Example: Tunneling deployment ─────────────────────────────────────────────
# VITE_APP_NAME=TunnelForce
# NICHE_APP_NAME=TunnelForce
# VITE_NICHE_ID=tunneling
# VITE_NICHE_DISPLAY=Tunneling & Underground Construction
# VITE_NICHE_TAGLINE=Connecting the best underground talent with the firms that need them.
# NICHE_DISPLAY=Tunneling & Underground Construction
# VITE_NICHE_INDUSTRIES=Tunnel Boring Machine,NATM,Cut and Cover,Shaft Sinking,Underground Utilities
# NICHE_INDUSTRIES=Tunnel Boring Machine,NATM,Cut and Cover,Shaft Sinking,Underground Utilities
# VITE_MARKET_SOC=47-2171
# VITE_MARKET_LOCATION=California
# VITE_MARKET_JOB_TITLE=Tunnel Superintendent

# ── Example: Renewable Energy deployment ──────────────────────────────────────
# VITE_APP_NAME=RenewBuild
# NICHE_APP_NAME=RenewBuild
# VITE_NICHE_ID=renewable
# VITE_NICHE_DISPLAY=Renewable Energy Construction
# VITE_NICHE_TAGLINE=Connecting the best renewable energy talent with the firms building tomorrow.
# NICHE_DISPLAY=Renewable Energy Construction
# VITE_NICHE_INDUSTRIES=Solar Farm Construction,Wind Farm Construction,BESS & Storage,Transmission & Substation,EV Infrastructure
# NICHE_INDUSTRIES=Solar Farm Construction,Wind Farm Construction,BESS & Storage,Transmission & Substation,EV Infrastructure
# VITE_MARKET_SOC=47-2211
# VITE_MARKET_LOCATION=Texas
# VITE_MARKET_JOB_TITLE=Solar Construction Superintendent

# ── API keys (required for all deployments) ───────────────────────────────────
ANTHROPIC_API_KEY=
CAREERONESTOP_USER_ID=
CAREERONESTOP_TOKEN=
FIREBASE_ADMIN_CREDENTIALS=
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
